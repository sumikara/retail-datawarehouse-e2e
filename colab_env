        "        SELECT\n",
        "            ss.store_src_id,\n",
        "            ss.store_name,\n",
        "            ss.store_location_nk,\n",
        "            COALESCE(a.address_id, -1) AS address_id\n",
        "        FROM src_stores ss\n",
