        "            ON a.address_src_id = ss.address_src_id\n",
        "    ),\n",
        "    ranked_stores AS (\n",
        "        SELECT\n",
        "            r.*,\n",
        "            ROW_NUMBER() OVER (\n",
        "                PARTITION BY r.store_src_id\n",
        "                ORDER BY r.address_id DESC, r.store_name\n",
        "            ) AS rn\n",
