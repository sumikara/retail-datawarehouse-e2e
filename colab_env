        "    WITH src_stores AS (\n",
        "        SELECT\n",
        "            s.store_src_id,\n",
        "            s.store_name,\n",
        "            s.store_location_nk,\n",
        "            COALESCE(s.store_city, 'n.a.') || '-' ||\n",
        "            COALESCE(s.store_state, 'n.a.') || '-' ||\n",
        "            COALESCE(s.store_zip_code, 'n.a.') AS address_src_id\n",
        "        FROM stg.mapping_stores s\n",
        "        WHERE s.store_src_id <> 'n.a.'\n",
        "    ),\n",
