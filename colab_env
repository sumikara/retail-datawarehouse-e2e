      "source": [
        "%%bash\n",
        "set -e\n",
        "#employee test\n",
        "DB=\"retail_dw\"\n",
        "sudo -u postgres psql -d \"$DB\" -v ON_ERROR_STOP=1 -P pager=off <<'SQL'\n",
        "\n",
        "SELECT 'total_rows' AS metric, COUNT(*)::TEXT AS value\n",
        "FROM nf.nf_employees_scd\n",
        "UNION ALL\n",
        "SELECT 'distinct_employee_src_id', COUNT(DISTINCT employee_src_id)::TEXT\n",
        "FROM nf.nf_employees_scd\n",
        "UNION ALL\n",
        "SELECT 'active_rows', COUNT(*)::TEXT\n",
        "FROM nf.nf_employees_scd\n",
        "WHERE is_active = TRUE\n",
        "UNION ALL\n",
        "SELECT 'inactive_rows', COUNT(*)::TEXT\n",
        "FROM nf.nf_employees_scd\n",
        "WHERE is_active = FALSE\n",
        "UNION ALL\n",
        "SELECT 'employees_with_history', COUNT(*)::TEXT\n",
        "FROM (\n",
        "    SELECT employee_src_id\n",
        "    FROM nf.nf_employees_scd\n",
        "    WHERE employee_id <> -1\n",
        "    GROUP BY employee_src_id\n",
        "    HAVING COUNT(*) > 1\n",
        ") x\n",
        "UNION ALL\n",
        "SELECT 'active_duplicate_keys', COUNT(*)::TEXT\n",
        "FROM (\n",
        "    SELECT employee_src_id\n",
        "    FROM nf.nf_employees_scd\n",
        "    WHERE is_active = TRUE\n",
        "    GROUP BY employee_src_id\n",
        "    HAVING COUNT(*) > 1\n",
        ") x\n",
        "UNION ALL\n",
        "SELECT 'overlap_cases', COUNT(*)::TEXT\n",
        "FROM (\n",
        "    WITH ordered AS (\n",
        "        SELECT\n",
        "            employee_src_id,\n",
        "            start_dt,\n",
        "            end_dt,\n",
        "            LEAD(start_dt) OVER (PARTITION BY employee_src_id ORDER BY start_dt) AS next_start_dt\n",
        "        FROM nf.nf_employees_scd\n",
        "        WHERE employee_id <> -1\n",
        "    )\n",
        "    SELECT 1\n",
        "    FROM ordered\n",
        "    WHERE next_start_dt IS NOT NULL\n",
        "      AND end_dt > next_start_dt\n",
        ") x;\n",
        "SQL"
