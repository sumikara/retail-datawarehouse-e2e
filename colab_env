    {
      "cell_type": "code",
      "source": [
        "%%bash\n",
        "set -e\n",
        "#employee test\n",
        "DB=\"retail_dw\"\n",
        "sudo -u postgres psql -d \"$DB\" -v ON_ERROR_STOP=1 -P pager=off <<'SQL'\n",
        "\n",
        "\\x on\n",
        "WITH changed_employees AS (\n",
        "    SELECT employee_src_id\n",
        "    FROM nf.nf_employees_scd\n",
        "    WHERE employee_id <> -1\n",
        "    GROUP BY employee_src_id\n",
        "    HAVING COUNT(*) = 2\n",
        "    ORDER BY employee_src_id\n",
        "    LIMIT 4\n",
        "),\n",
        "ranked AS (\n",
        "    SELECT\n",
        "        employee_src_id,\n",
        "        employee_name_nk,\n",
        "        employee_position,\n",
        "        employee_salary,\n",
        "        start_dt,\n",
        "        end_dt,\n",
        "        is_active,\n",
        "        ROW_NUMBER() OVER (\n",
        "            PARTITION BY employee_src_id\n",
        "            ORDER BY start_dt\n",
        "        ) AS version_order\n",
        "    FROM nf.nf_employees_scd\n",
        "    WHERE employee_id <> -1\n",
        "      AND employee_src_id IN (\n",
        "          SELECT employee_src_id\n",
        "          FROM changed_employees\n",
        "      )\n",
        ")\n",
        "SELECT\n",
        "    CASE\n",
        "        WHEN version_order = 1 THEN 'OLD_VERSION'\n",
        "        WHEN version_order = 2 THEN 'NEW_VERSION'\n",
        "    END AS version_label,\n",
        "    employee_src_id,\n",
        "    employee_name_nk,\n",
        "    employee_position,\n",
        "    employee_salary,\n",
        "    start_dt,\n",
        "    end_dt,\n",
        "    is_active\n",
        "FROM ranked\n",
        "ORDER BY employee_src_id, start_dt;\n",
        "\n",
        "SQL"
