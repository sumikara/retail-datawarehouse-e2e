        "   ========================================================= */\n",
        "\n",
        "CREATE OR REPLACE PROCEDURE stg.load_map_engagements()\n",
        "LANGUAGE plpgsql\n",
        "AS $$\n",
        "DECLARE\n",
        "    v_proc        TEXT := 'stg.load_map_engagements';\n",
        "    v_ins         INT  := 0;\n",
        "    v_err_msg     TEXT;\n",
        "    v_err_detail  TEXT;\n",
        "    v_err_hint    TEXT;\n",
        "BEGIN\n",
