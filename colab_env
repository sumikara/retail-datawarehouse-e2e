        "        CASE WHEN (v_ins ) > 0 THEN 'SUCCESS' ELSE 'NO_CHANGE' END,\n",
        "        'Inserted=' || v_ins ||  '. Delivery load by delivery_src_id.',\n",
        "        NULL,\n",
        "        'INFO',\n",
        "        v_ins,\n",
        "        0,\n",
        "        0,\n",
        "        NULL\n",
        "    );\n",
        "        RAISE NOTICE 'nf.nf_deliveries completed. inserted=%', v_ins;\n",
        "\n",
